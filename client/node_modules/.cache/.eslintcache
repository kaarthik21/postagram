ents\\Auth\\Input.js",[],[],"D:\\vscode\\postagram\\client\\src\\components\\Posts\\Posts.js",[],[],"D:\\vscode\\postagram\\client\\src\\actions\\posts.js",["116","117","118","119"],[],"import { FETCH_ALL, CREATE, DELETE, LIKE } from '../constants/actionTypes';\r\nimport * as api from '../api/index.js';\r\n\r\n// try lets u knwo the errors, catch lets handle the errors\r\nexport const getPosts = () => async (dispatch) => {\r\n  try {\r\n    const { data } = await api.fetchPosts();\r\n    dispatch({ type: FETCH_ALL, payload: data });\r\n  } catch (error) {\r\n    console.log(error);\r\n  }\r\n};\r\n\r\nexport const createPost = (post) => async (dispatch) => {\r\n  try {\r\n    const { data } = await api.createPost(post);\r\n    dispatch({ type: CREATE, payload: data });\r\n  } catch (error) {\r\n    console.log(error);\r\n  }\r\n};\r\n\r\nexport const likePost = (id) => async (dispatch) => {\r\n  const user = JSON.parse(localStorage.getItem('profile'));\r\n  try {\r\n    const { data } = await api.likePost(id, user?.token);\r\n    dispatch({ type: LIKE, payload: data });\r\n  } catch (error) {\r\n    console.log(error);\r\n  }\r\n};\r\n\r\nexport const deletePost = (id) => async (dispatch) => {\r\n  try {\r\n    await await api.deletePost(id);\r\n    dispatch({ type: DELETE, payload: id });\r\n  } catch (error) {\r\n    console.log(error);\r\n  }\r\n};\r\n","D:\\vscode\\postagram\\client\\src\\components\\Navbar\\styles.js",[],[],"D:\\vscode\\postagram\\client\\src\\components\\Form\\Form.js",[],[],"D:\\vscode\\postagram\\client\\src\\api\\index.js",[],[],"D:\\vscode\\postagram\\client\\src\\components\\Posts\\styles.js",[],[],"D:\\vscode\\postagram\\client\\src\\components\\Form\\styles.js",[],[],"D:\\vscode\\postagram\\client\\src\\components\\Posts\\Post\\Post.js",[],[],"D:\\vscode\\postagram\\client\\src\\components\\Posts\\Post\\styles.js",[],[],{"ruleId":"120","severity":1,"message":"121","line":10,"column":5,"nodeType":"122","messageId":"123","endLine":10,"end